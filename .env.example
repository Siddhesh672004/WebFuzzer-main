# ─────────────────────────────────────────────────────────────
# SmartFuzz environment configuration
# Copy to `.env` and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# ── Core ──
NODE_ENV=development
# Backend HTTP port
PORT=4000
# Public origin of the frontend (used for CORS allow-list + cookie domain)
FRONTEND_ORIGIN=http://localhost:5173

# ── Data layer ──
MONGO_URI=mongodb://localhost:27017/smartfuzz
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional Redis auth (leave blank for local)
REDIS_PASSWORD=

# ── Auth / JWT ──
# Generate a strong secret: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=change-me-to-a-long-random-string
# Token lifetime (jsonwebtoken format)
JWT_EXPIRES_IN=7d
# Cookie name for the JWT
AUTH_COOKIE_NAME=smartfuzz_token

# ── OTP ──
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=3
# Throttle: minimum seconds between OTP resends to the same email
OTP_RESEND_COOLDOWN_SECONDS=60

# ── Email (Nodemailer) ──
# In development, leave MAIL_TRANSPORT=ethereal to auto-create a fake SMTP
# inbox that returns a preview URL in the logs — no real email needed.
# For real delivery use Gmail SMTP with an App Password (2FA required).
MAIL_TRANSPORT=ethereal
MAIL_FROM=SmartFuzz <no-reply@smartfuzz.local>
# Gmail SMTP (only used when MAIL_TRANSPORT=gmail)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Scan safety ──
# Default outbound rate limit (requests/second) shared across all modules
SCAN_RATE_LIMIT=10
# Crawler bounds
SCAN_MAX_DEPTH=3
SCAN_MAX_ENDPOINTS=500
# Per-request timeout (ms) and per-scan wall-clock budget (ms)
SCAN_REQUEST_TIMEOUT_MS=10000
SCAN_WALLCLOCK_BUDGET_MS=1800000
# Max response body captured/stored (bytes)
SCAN_MAX_BODY_BYTES=2097152
# DANGER: allow scanning private/reserved IP ranges (localhost, RFC1918, etc.)
# Required to scan local DVWA/WebGoat. MUST be false in any shared deployment.
SCAN_ALLOW_PRIVATE=false

# ── Worker ──
# Concurrency per fuzz queue
WORKER_FUZZ_CONCURRENCY=5
# True = split a scan into one BullMQ job per module (Redis-coordinated fan-out);
# false (default) = the single-process ScanRunner runs every module.
WORKER_FANOUT=false

# ── Screenshot evidence (Puppeteer) ──
# Capture a PNG proving an XSS/open-redirect fired. Off by default so the build
# stays browser-free; needs Chromium when enabled.
SCAN_SCREENSHOTS=false
SCREENSHOT_DIR=/tmp/smartfuzz-screenshots

# ── Headless crawler (P2.1, opt-in) ──
# Use the Puppeteer/Chromium already present (no extra dependency) to crawl
# SPA / JS-rendered targets. Falls back to the static cheerio crawler on failure.
SCAN_HEADLESS_CRAWLER=false
HEADLESS_MAX_PAGES=20
HEADLESS_TIMEOUT_MS=15000
# Optional: path to a system Chromium (shared with screenshots)
# PUPPETEER_EXECUTABLE_PATH=

# ── AI payload generation (context-aware, Gemini-powered) ──
# This build ships with AI payload generation ENABLED. For every fuzzable
# parameter the engine asks the model for attack payloads tailored to that
# parameter's name, input type, and inferred category, then appends them on top
# of the deterministic curated/wordlist baseline. Confirmed critical/high
# findings get a second adaptive pass that requests escalation/bypass variants.
#
# Modes:
#   gemini = free Google Gemini REST API  (default here; needs GEMINI_API_KEY)
#   ollama = local Ollama server          (fully offline, no key)
#   off    = curated/wordlist payloads only (no network, no AI)
#
# Get a free Gemini API key at https://aistudio.google.com/apikey and paste it
# below. If the key is missing or the free-tier quota is exhausted (HTTP 429),
# the engine transparently falls back to curated payloads — scans never fail.
AI_PAYLOAD_MODE=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
# Circuit breaker: suppress AI calls for this long after a 429 (ms)
AI_PAYLOAD_RATE_LIMIT_COOLDOWN_MS=120000
# Max AI payloads appended per attack type per param
AI_PAYLOAD_MAX_PER_TYPE=5

# ── Demo mode (P6.2) ──
# Pre-fills the New Scan page with an authorized public test target + banner.
SMARTFUZZ_DEMO_MODE=false
SMARTFUZZ_DEMO_TARGET=http://testphp.vulnweb.com
