# ─────────────────────────────────────────────────────────────
# SmartFuzz environment configuration
# Copy to `.env` and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# ── Core ──
NODE_ENV=development
# Backend HTTP port
PORT=4000
# Public origin of the frontend (used for CORS allow-list + cookie domain)
FRONTEND_ORIGIN=http://localhost:5173

# ── Data layer ──
MONGO_URI=mongodb://localhost:27017/smartfuzz
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional Redis auth (leave blank for local)
REDIS_PASSWORD=

# ── Auth / JWT ──
# Generate a strong secret: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=change-me-to-a-long-random-string
# Token lifetime (jsonwebtoken format)
JWT_EXPIRES_IN=7d
# Cookie name for the JWT
AUTH_COOKIE_NAME=smartfuzz_token

# ── OTP ──
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=3
# Throttle: minimum seconds between OTP resends to the same email
OTP_RESEND_COOLDOWN_SECONDS=60

# ── Email (Nodemailer) ──
# In development, leave MAIL_TRANSPORT=ethereal to auto-create a fake SMTP
# inbox that returns a preview URL in the logs — no real email needed.
# For real delivery use Gmail SMTP with an App Password (2FA required).
MAIL_TRANSPORT=ethereal
MAIL_FROM=SmartFuzz <no-reply@smartfuzz.local>
# Gmail SMTP (only used when MAIL_TRANSPORT=gmail)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Scan safety ──
# Default outbound rate limit (requests/second) shared across all modules
SCAN_RATE_LIMIT=10
# Crawler bounds
SCAN_MAX_DEPTH=3
SCAN_MAX_ENDPOINTS=500
# Per-request timeout (ms) and per-scan wall-clock budget (ms)
SCAN_REQUEST_TIMEOUT_MS=10000
SCAN_WALLCLOCK_BUDGET_MS=1800000
# Max response body captured/stored (bytes)
SCAN_MAX_BODY_BYTES=2097152
# DANGER: allow scanning private/reserved IP ranges (localhost, RFC1918, etc.)
# Required to scan local DVWA/WebGoat. MUST be false in any shared deployment.
SCAN_ALLOW_PRIVATE=false

# ── Worker ──
# Concurrency per fuzz queue
WORKER_FUZZ_CONCURRENCY=5
